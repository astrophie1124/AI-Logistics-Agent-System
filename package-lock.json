const { Client, LocalAuth } = require('whatsapp-web.js');
const qrcode = require('qrcode-terminal');
const express = require('express');
const axios = require('axios');

const app = express();
app.use(express.json());

// ⚠️ 这里填入你 n8n 的 Webhook Test URL
const N8N_WEBHOOK_URL = 'http://localhost:5678/webhook/whatsapp-webhook'; 

// 初始化 WhatsApp 客户端 (LocalAuth 会在本地保存登录状态，不用每次扫码)
const client = new Client({
    authStrategy: new LocalAuth() 
});

client.on('qr', (qr) => {
    qrcode.generate(qr, {small: true});
    console.log('👉 Please scan the QR code above using WhatsApp on your mobile phone');
});

client.on('ready', () => {
    console.log('✅ WhatsApp connection successful! The API service is now ready.');
});

// 监听收到的消息
client.on('message_create', async msg => {
    // 防御死循环与广播
    if (msg.fromMe && !msg.body.startsWith('/test')) return;
    if (msg.from === 'status@broadcast') return;
    
    try {
        // 1. 确定来源身份
        const roomId = msg.from;             // 永远代表“聊天室”。群聊 @g.us，私聊 @c.us
        const authorId = msg.author || msg.from; // 永远代表“发话人”。只会有 @c.us
        
        let base64Media = null;
        let mimeType = null;

        // 2. 多模态拦截 - 发现媒体文件，只下载一次
        if (msg.hasMedia) {
            console.log(`📥 Downloading images/media from ${authorId}...`);
            const media = await msg.downloadMedia();
            if (media) {
                base64Media = media.data; // 获取 Base64 字符串
                mimeType = media.mimetype;
            }
        }

        console.log(`Received a message [Type: ${msg.type}]: ${msg.body}`);

        // 3. 组装终极 Payload
        const payload = {
            from: roomId,       // 传给 n8n，让 n8n 知道该往哪个群/私聊回复
            author: authorId,   // 传给 n8n，记录具体是哪个客户在说话（用于老板报警）
            body: msg.body,
            type: msg.type,
            media: base64Media,
            mimeType: mimeType
        };

        // 4. 正式推送给 n8n
        await axios.post(N8N_WEBHOOK_URL, payload);
        console.log(`✅ Successfully posted to n8n! (Room: ${roomId})`);

    } catch (err) {
        console.error('❌ Failed to process or push to n8n:', err.message);
    }
});



client.initialize();

// ---------------------------------------------------------
// 4. 提供给 n8n 调用的发送接口 
// ---------------------------------------------------------
app.post('/send', async (req, res) => {
    const { number, text } = req.body;
    
    if (!number) {
        console.error('❌ 接收到的号码为空！');
        return res.status(400).send({ error: 'Missing phone number' });
    }

    // 🌟 核心修复：智能识别并补全尾巴
    let chatId = String(number).trim();
    if (!chatId.includes('@')) {
        chatId = `${chatId}@c.us`; 
    }
    
    try {
        // === 🚨 架构师防封伪装机制开始 🚨 ===
        
        // 1. 获取聊天对象 (群聊或私聊)
        const chat = await client.getChatById(chatId);
        
        // 2. 触发 "正在输入..." 状态 (让群里的人看到机器人在打字)
        await chat.sendStateTyping();
        console.log(`⏳ Simulating typing to: ${chatId}...`);
        
        // 3. 随机延迟 2 到 4 秒 (模拟真实打字速度，2000ms - 4000ms)
        const delayTime = Math.floor(Math.random() * 2000) + 2000;
        await new Promise(resolve => setTimeout(resolve, delayTime));
        
        // 4. 延迟结束，正式发送消息
        await client.sendMessage(chatId, text);
        
        // 5. 清楚 "正在输入..." 状态
        await chat.clearState();
        
        // === 🚨 防封伪装机制结束 🚨 ===

        console.log(`✅ Message successfully sent to: ${chatId}`);
        res.send({ status: 'success' });
    } catch (err) {
        console.error('❌ Failed to send:', err); 
        res.status(500).send({ error: err.toString() });
    }
});

app.listen(3000, () => {
    console.log('🚀 The local sending interface has been started on: http://localhost:3000/send');
});